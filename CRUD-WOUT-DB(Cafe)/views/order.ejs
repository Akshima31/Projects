<!DOCTYPE html>
<html>
<head>
<title>Place Order</title>

<style>

body{
margin:0;
padding:40px;
background:url('/orders.jpg') no-repeat center center/cover;
font-family:Arial;
color:white;
}

.container{
max-width:1100px;
margin:auto;
padding:40px;
border-radius:20px;
background:rgba(255,255,255,0.15);
backdrop-filter:blur(15px);
box-shadow:0 8px 32px rgba(0,0,0,0.3);
}

.menu{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
}

.card{
background:rgba(255,255,255,0.2);
border-radius:10px;
text-align:center;
padding-bottom:15px;
}

.card img{
width:100%;
height:150px;
object-fit:cover;
border-radius:10px 10px 0 0;
}

button{
padding:8px 15px;
border:none;
border-radius:6px;
background:rgb(126, 38, 38);
color:white;
cursor:pointer;
}

button:hover{
background:chocolate;
}

.top{
display:flexbox;
margin-bottom:25px;
}
.top h1{
    text-align: center;
}

</style>

</head>

<body>

<div class="container">

<div class="top">
<h1 >MENU</h1>
<a href="/bill" ><button>View Bill</button></a>
<a href="/"><button>Back</button></a>
</div>

<div class="menu">

<% menu.forEach(item => { %>

<div class="card">

<img src="<%= item.image %>">

<h3><%= item.name %></h3>

<p>₹ <%= item.price %></p>

<form action="/add-item/<%= item.id %>" method="POST">
<button>Add Item</button>
</form>

</div>

<% }) %>

</div>

</div>

</body>
</html>

