<!DOCTYPE html>
<html>
<head>
<title>Dashboard</title>

<style>

body{
    margin:0;
    min-height:100vh;
    background:url('/dashboard.jpg') no-repeat center center/cover;
    font-family: Arial, sans-serif;
}

/* Section wrapper */
.sections{
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:50px;
    padding:60px 0;
}

/* Glass container */
.container{
    width:500px;
    padding:35px;
    border-radius:20px;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(15px);
    box-shadow:0 8px 32px rgba(0,0,0,0.3);
    text-align:center;
    color:white;
}

/* Button group */
.button-group{
    display:flex;
    justify-content:space-between;
    margin-top:20px;
}

/* Buttons */
button{
    padding:12px 20px;
    border:none;
    border-radius:10px;
    background:#8b5e3c;
    color:white;
    font-weight:bold;
    cursor:pointer;
    transition:0.3s;
}

button:hover{ background:#5c4033;   
}
h1{
    margin-bottom:10px;
    color:whitesmoke
}
p{
    margin-top:15px;
    color: whitesmoke
}

</style>

</head>
<body>

<div class="sections">

    <!-- Welcome Container -->
    <div class="container">
        <h1>Welcome, <%= user.username %></h1>
    </div>

    <!-- Staff Management Container -->
    <div class="container">
        <h1>Staff Management</h1>

        <div class="button-group">
            <form action="/add">
                <button type="submit">ADD</button>
            </form>

            <form action="/view">
                <button type="submit">VIEW</button>
            </form>

            <form action="/add">
                <button type="submit">EDIT</button>
            </form>

            <form action="/add">
                <button type="submit">DELETE</button>
            </form>
        </div>

        <p>Manage staff records efficiently.</p>
    </div>

    <!-- Order Management Container -->
    <div class="container">
        <h1>Order Management</h1>

        <div class="button-group">
            <form action="/order">
                <button type="submit">Place Order</button>
            </form>

            <form action="/viewOrder">
                <button type="submit">View Orders</button>
            </form>
        </div>

        <p>Manage customer orders easily.</p>
    </div>

</div>

</body>
</html>