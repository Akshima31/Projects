<!DOCTYPE html>
<html>
<head>
<title>Login</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
<style>
:root {
    --bg-color: linear-gradient(150deg, black , rgb(39, 37, 37) , rgb(58, 55, 55));
    --surface-color: rgb(46, 43, 46);
    --text-primary: #f8fafc;
    --text-secondary: wheat;
    --accent: rgba(214, 83, 133, 0.918);
    --accent-hover: rgba(226, 63, 172, 0.836);
    --border: rgba(214, 83, 133, 0.918);
}

body{
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background: var(--bg-color);
    font-family: 'Inter', sans-serif;
    color: var(--text-primary);
}

/* Same card style as index */
.container{
    width:500px;
    padding:40px;
    border-radius:16px;
    background: rgb(43, 33, 33);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    box-shadow: 0 4px 30px rgba(70, 69, 69, 0.726);
    text-align:center;
}

/* Heading */
h2{
    margin-bottom:25px;
    font-weight:800;
    font-size:1.8rem;
    background: linear-gradient(rgba(196, 69, 118, 0.918));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

/* Inputs same as index */
input{
    width:95%;
    padding:12px;
    margin:12px 0;
    border-radius:8px;
    border:1px solid var(--border);
    background:black;
    color:white;
    outline:none;
    transition:0.3s;
}

input::placeholder{
    color:white;
}

input:focus{
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(27, 6, 27, 0.37);
}

label {
            display: block;
            font-weight: 600;
            color: var(--text-secondary);
            font-size: 16px;
            text-align: left;
        }

/* Button same as index */
button{
    width:100%;
    padding:12px;
    margin-top:15px;
    border:none;
    border-radius:8px;
    background: var(--accent);
    color:white;
    font-weight:600;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    background: var(--accent-hover);
    transform: translateY(-2px);
}

/* Link styling */
.link{
    margin-top:15px;
    font-size:14px;
    color: var(--text-secondary);
}

.link a{
    color: var(--accent);
    text-decoration:none;
    font-weight:600;
}

.link a:hover{
    text-decoration:underline;
    color:rgba(63, 162, 201, 0.73);
}


</style>
</head>
<body>
<div style="width:100%; max-width:640px; margin:2rem auto;">
        <div class="container">
            <h2 style="margin-top:0;">Create Account</h2>
            <% if (error) { %>
                <div class="error"><%= error %></div>
            <% } %>
            <% if (success) { %>
                <div class="success">Account created successfully. <a href="/" style="color:rgba(63, 162, 201, 0.73);">Back to Login</a></div>
            <% } %>
            <form action="/add" method="POST">
                <div>
                    <label for="name">Full Name</label>
                    <input type="text" id="name" name="name" required placeholder="Ex. Alexander Smith">
                </div>
                <div style="margin-top:0.75rem;">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required placeholder="alex@company.com">
                </div>
                <div style="margin-top:0.75rem;">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required placeholder="Choose a password">
                </div>
                <div style="margin-top:0.75rem;">
                    <label for="role">Role</label>
                    <input type="text" id="role" name="role" required placeholder="Administrator">
                </div>
                <button class="btn" type="submit">Sign Up</button>
            </form>
            <div style="margin-top:0.75rem;" class="link">
                Already have an account? 
                <a class="cancel" href="/">Login</a>
            </div>
        </div>
    </div>
</body>
</html>
