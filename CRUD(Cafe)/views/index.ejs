<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CRUD Application</title>
    <!-- Importing modern typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: linear-gradient(150deg, black , rgb(39, 37, 37) , rgb(58, 55, 55) ) ;
            --surface-color: rgb(46, 43, 46);
            --text-primary: #f8fafc;
            --text-secondary: wheat;
            --accent: rgba(214, 83, 133, 0.918);
            --accent-hover: rgba(226, 63, 172, 0.836);
            --danger: rgba(233, 85, 85, 0.74);
            --danger-hover: #dc2626c4;
            --success: #10b981ec;
            --border: rgba(214, 83, 133, 0.918);
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            background: var(--bg-color);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            width: 100%;
            max-width: 900px;
            padding: 2rem;
            margin-top: 3rem;
            box-sizing: border-box;
        }

        .header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .header h1 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            background: linear-gradient(rgba(196, 69, 118, 0.918));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        

        /* Glassmorphism Card Aesthetics */
        .card {
            background: rgb(43, 33, 33);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 4px 30px rgba(70, 69, 69, 0.726);
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        input[type="text"], input[type="email"] {
            width: 100%;
            padding: 0.8rem 1rem;
            background: black;
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text-primary);
            font-family: 'Inter', sans-serif;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }
         input[type="text"]::placeholder, input[type="email"]::placeholder{
              color: white;
         }
        input:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(27, 6, 27, 0.37);
        }

        .btn {
            display: inline-block;
            padding: 0.8rem 1.5rem;
            border: none;
            border-radius: 8px;
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            text-align: center;
        }

        .btn-primary {
            background: var(--accent);
            color: white;
            width: 100%;
            margin-top: 1rem;
        }

        .btn-primary:hover {
            background: var(--accent-hover);
            transform: translateY(-2px);
        }

        .btn-sm {
            padding: 0.4rem 1rem;
            font-size: 0.85rem;
        }

        .btn-edit { background: var(--success); color: white; margin-right: 0.5rem; }
        .btn-edit:hover { background: #06815adc; transform: translateY(-1px); }
        .btn-delete { background: var(--danger); color: white; }
        .btn-delete:hover { background: var(--danger-hover); transform: translateY(-1px); }

        .table-container {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 1rem;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        th {
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.05em;
        }

        tr { transition: background 0.3s ease; }
        tr:hover { background: rgba(255, 255, 255, 0.02); }

        .actions-form { display: inline-block; margin: 0; }
    </style>
</head>
<body>

    <div class="container">
        <div class="header">
            <h1>User Dashboard</h1>
            </div>

        <div class="card">
            <h2 style="margin-top:0; font-size:1.3rem;">Register Next User</h2>
            <form action="/add" method="POST">
                <div class="form-group">
                    <label for="name">Full Name</label>
                    <input type="text" id="name" name="name" required placeholder="Enter Your Full Name">
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required placeholder="Enter your Mail">
                </div>
                <div class="form-group">
                    <label for="role">Role</label>
                    <input type="text" id="role" name="role" required placeholder="Ex. Admin , User">
                </div>
                <button type="submit" class="btn btn-primary">Add User</button>
            </form>
        </div>

        <div class="card">
            <h2 style="margin-top:0; font-size:1.3rem; margin-bottom: 1.5rem;">System Database Records</h2>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>User Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th> Database Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(users && users.length > 0) { %>
                            <% users.forEach(user => { %>
                                <tr>
                                    <td style="font-weight: 600;"><%= user.name %></td>
                                    <td style="color: var(--text-secondary);"><%= user.email %></td>
                                    <td>
                                        <span style="background: rgba(59,130,246,0.15); color: #60a5fa; padding: 6px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em;">
                                            <%= user.role %>
                                        </span>
                                    </td>
                                    <td>
                                        <a href="/edit/<%= user._id %>" class="btn btn-sm btn-edit">Modify</a>
                                        <form action="/delete/<%= user._id %>" method="POST" class="actions-form" onsubmit="return confirm('Confirm permanent deletion?');">
                                            <button type="submit" class="btn btn-sm btn-delete">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" style="text-align:center; padding: 3rem 0; color: var(--text-secondary);">
                                    <div style="font-size: 2rem; margin-bottom: 1rem;">📭</div>
                                         No User found 
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</body>
</html>
